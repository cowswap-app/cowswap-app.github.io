:root{
  --bg:#F7F8FA;
  --surface:#FFFFFF;
  --surface-soft:#F1F4F8;
  --ink:#101418;
  --muted:#66717E;
  --faint:#9AA4B0;
  --line:rgba(16,20,24,.10);
  --line-strong:rgba(16,20,24,.16);
  --accent:#3F76E0;
  --accent-soft:rgba(63,118,224,.12);
  --shadow:0 26px 70px -38px rgba(16,20,24,.34);
}

*{box-sizing:border-box}
html,body{height:100%}
body{
  margin:0;
  min-height:100dvh;
  height:100dvh;
  overflow:hidden;
  background:
    radial-gradient(circle at 50% -12%, rgba(63,118,224,.13), transparent 40%),
    linear-gradient(180deg, #FFFFFF 0%, var(--bg) 56%, #EEF1F5 100%);
  color:var(--ink);
  font-family:Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  line-height:1.5;
  -webkit-font-smoothing:antialiased;
  display:grid;
  grid-template-rows:auto 1fr auto;
}

a{color:inherit;text-decoration:none}
img{display:block;max-width:100%}
h1,p{margin:0}
h1{font-size:clamp(3rem, 7vw, 5.5rem);line-height:.98;font-weight:800;letter-spacing:0}

.topbar{
  display:flex;
  align-items:center;
  gap:18px;
  padding:18px clamp(18px, 4vw, 44px);
}

.brand{
  display:inline-flex;
  align-items:center;
  gap:10px;
  min-width:0;
  color:var(--ink);
  font-weight:800;
  font-size:1.06rem;
}

.brand img{
  width:30px;
  height:30px;
  border-radius:50%;
  box-shadow:0 0 0 1px rgba(16,20,24,.06);
}

.brand span{white-space:nowrap}

.nav{
  display:flex;
  align-items:center;
  gap:26px;
  margin-left:10px;
}

.nav a{
  color:var(--muted);
  font-size:.93rem;
  font-weight:550;
  transition:color .16s ease;
}

.nav a:hover{color:var(--ink)}
.spacer{flex:1}

.ghost{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-height:40px;
  padding:0 18px;
  border:1px solid var(--line-strong);
  border-radius:999px;
  background:rgba(255,255,255,.64);
  color:var(--ink);
  font-size:.91rem;
  font-weight:750;
  box-shadow:0 10px 26px -22px rgba(16,20,24,.45);
  transition:transform .14s ease, border-color .16s ease, background .16s ease;
  white-space:nowrap;
}

.ghost:hover{
  transform:translateY(-1px);
  border-color:rgba(63,118,224,.42);
  background:#FFFFFF;
}

.stage{
  min-height:0;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:30px;
  padding:12px clamp(18px, 4vw, 44px);
  text-align:center;
}

.hero{
  display:flex;
  flex-direction:column;
  align-items:center;
}

.sub{
  max-width:760px;
  margin-top:18px;
  color:var(--muted);
  font-size:clamp(1rem, 1.75vw, 1.24rem);
}

.sub strong{
  color:var(--ink);
  font-weight:800;
}

.swap-card{
  width:min(560px, 100%);
  padding:22px;
  border:1px solid var(--line);
  border-radius:22px;
  background:rgba(255,255,255,.88);
  box-shadow:var(--shadow);
  backdrop-filter:blur(16px);
}

.route{
  display:grid;
  grid-template-columns:minmax(0, 1fr) 46px minmax(0, 1fr);
  align-items:center;
  gap:12px;
}

.leg{
  min-width:0;
  border:1px solid var(--line);
  border-radius:16px;
  background:linear-gradient(180deg, #FFFFFF 0%, var(--surface-soft) 100%);
  padding:15px 16px;
  text-align:left;
}

.label{
  display:block;
  color:var(--faint);
  font-size:.72rem;
  font-weight:800;
  letter-spacing:.08em;
  text-transform:uppercase;
}

.asset{
  display:flex;
  align-items:center;
  gap:10px;
  min-width:0;
  margin-top:10px;
  color:var(--ink);
  font-size:1.1rem;
  font-weight:850;
}

.asset img{
  width:28px;
  height:28px;
  border-radius:50%;
  flex:none;
}

.asset span{
  min-width:0;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}

.switch{
  width:46px;
  height:46px;
  border:1px solid var(--line-strong);
  border-radius:50%;
  background:#FFFFFF;
  color:var(--accent);
  cursor:pointer;
  display:grid;
  place-items:center;
  box-shadow:0 12px 26px -24px rgba(16,20,24,.5);
  transition:transform .18s ease, background .16s ease, border-color .16s ease;
}

.switch span{
  display:block;
  font-size:1.18rem;
  line-height:1;
}

.switch:hover{
  background:var(--accent-soft);
  border-color:rgba(63,118,224,.38);
  transform:translateY(-1px);
}

.switch.turned{transform:rotate(180deg)}
.switch.turned:hover{transform:rotate(180deg) translateY(1px)}

.primary{
  display:flex;
  align-items:center;
  justify-content:center;
  min-height:54px;
  width:100%;
  margin-top:16px;
  border-radius:15px;
  background:var(--accent);
  color:#FFFFFF;
  font-size:1.05rem;
  font-weight:850;
  box-shadow:0 18px 34px -24px rgba(63,118,224,.85);
  transition:transform .14s ease, background .16s ease, box-shadow .16s ease;
}

.primary:hover{
  transform:translateY(-1px);
  background:var(--accent);
  filter:brightness(.94);
  box-shadow:0 22px 38px -24px rgba(63,118,224,.95);
}

.foot{
  padding:16px 24px 22px;
  color:var(--faint);
  font-size:.86rem;
  font-weight:650;
  text-align:center;
}

@media(max-width:720px){
  .topbar{padding:15px 18px}
  .nav{display:none}
  .brand{font-size:1rem}
  .ghost{min-height:38px;padding:0 15px}
  .stage{gap:24px;padding:4px 18px 10px}
  h1{font-size:clamp(3.05rem, 15vw, 4.6rem)}
  .sub{max-width:32ch;margin-top:14px;font-size:1.02rem;line-height:1.45}
  .swap-card{padding:18px;border-radius:20px}
  .route{grid-template-columns:1fr;gap:10px}
  .leg{padding:13px 14px}
  .switch{width:42px;height:42px;justify-self:center}
  .switch span{transform:rotate(90deg)}
  .primary{min-height:52px;margin-top:14px}
  .foot{padding:12px 18px 16px}
}

@media(max-width:390px){
  .topbar{gap:10px}
  .ghost{padding:0 13px}
  .swap-card{padding:16px}
  h1{font-size:3.1rem}
}
